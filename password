a=input("enter ur password: ")
up=0
sm=0
sp=0
dg=0
if len(a)>7:
    for i in a:
        if i.isupper():
            up=up+1
        elif i.islower():
            sm=sm+1
        elif i.isdigit():
            sp=sp+1
        else: 
            dg=dg+1
    if up >0 and sm>0 and sp>0 and dg>0:
        print("strong")
    else:
        print("weak")
else:
    print("weak due to less char")
                        
