legs=int(input("enter a number of legs: "))
heads=int(input("enter a number of heads:"))
flag=False
for cows in range(0,heads+1):
    hens=heads-cows
    cal_leg=cows*4+hens*2
    if cal_leg==legs:
        flag=True
        break
if flag:
    print("cows:",cows)
    print("hens:",hens)
else:
    print("no solution")
